# =============================================================
# backend/.env.example
#
# This file is committed to git. It documents every variable
# the backend needs and WHERE to find the real values.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. Never commit .env  (it is already in .gitignore)
# =============================================================


# -------------------------------------------------------------
# Server
# -------------------------------------------------------------

# The port the Express server listens on locally.
# The frontend's VITE_BASE_URL must point to this same port (http://localhost:8000).
# Vercel ignores this in production — it assigns its own port automatically.
PORT=8000


# -------------------------------------------------------------
# Database
# -------------------------------------------------------------

# --- Option A: Local Docker (for local development) ----------
# Start the container first with: docker compose up -d  (from project root)
# Credentials match docker-compose.yml: username=root, password=example
# The database name "thriveful" is created automatically on first connection.
MONGO_URL=mongodb://root:example@localhost:27017/thriveful?authSource=admin

# --- Option B: MongoDB Atlas (for production / cloud) --------
# 1. Go to https://cloud.mongodb.com
# 2. Open your cluster → Connect → Drivers
# 3. Copy the connection string and replace <password> with your DB user password.
# MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/thriveful?retryWrites=true&w=majority


# -------------------------------------------------------------
# Authentication
# -------------------------------------------------------------

# Secret string used to sign and verify JWT tokens.
# Any user with this secret can forge valid tokens — keep it private.
# For local dev any long string works.
# For production, generate a cryptographically random value:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET_KEY=replace_with_a_long_random_string


# -------------------------------------------------------------
# Payments
# -------------------------------------------------------------

# Stripe secret key — used server-side to create checkout sessions.
# Always use the TEST key (sk_test_...) for local dev — never the live key.
#
# Where to find it:
#   1. Go to https://dashboard.stripe.com/test/apikeys
#   2. Copy "Secret key" (starts with sk_test_...)
STRIPE_SECRET_KEY=sk_test_replace_me


# -------------------------------------------------------------
# Stripe redirect URLs
# -------------------------------------------------------------

# The frontend URL Stripe redirects users back to after payment.
# After a successful payment → redirects to {CLIENT_SITE_URL}/checkout-success
# After a cancelled payment → redirects to {CLIENT_SITE_URL}/doctors-details/:id
#
# Must match wherever your frontend is running:
# Local dev (matches Vite's default port):
CLIENT_SITE_URL=http://localhost:5173
# Production (set this in the Vercel dashboard instead of here):
# CLIENT_SITE_URL=https://health-booking-website-client.vercel.app

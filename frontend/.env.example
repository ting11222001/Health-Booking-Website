# =============================================================
# frontend/.env.example
#
# This file is committed to git. It documents every variable
# the frontend (Vite) needs and WHERE to find the real values.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. Never commit .env  (it is already in .gitignore)
#
# IMPORTANT — Vite rule:
#   Every variable MUST start with VITE_ or it will be
#   undefined in the browser, even if it is set here.
# =============================================================


# -------------------------------------------------------------
# Backend API URL
# -------------------------------------------------------------

# Points to your backend Express server.
# The frontend sends all API requests (login, fetch doctors, etc.) to this URL.
# Must match PORT in backend/.env — both are set to 8000 by default.
#
# Local dev:
VITE_BASE_URL=http://localhost:8000
#
# Production (set this in the Vercel dashboard, not here):
# VITE_BASE_URL=https://health-booking-website-server.vercel.app


# -------------------------------------------------------------
# Cloudinary  (profile photo uploads)
# -------------------------------------------------------------

# Your Cloudinary cloud name — used to build the upload URL in the browser.
# Your real value: dcr3ib98u
#
# Where to find it:
#   1. Go to https://cloudinary.com and log in.
#   2. Dashboard → top-left corner shows "Cloud Name".
VITE_CLOUD_NAME=your_cloud_name_here

# Your Cloudinary unsigned upload preset — controls upload rules (folder, format, etc.).
# Your real value: health-booking-website
#
# Where to find it:
#   1. Cloudinary → Settings (gear icon) → Upload tab.
#   2. Scroll to "Upload presets" → copy the preset name.
#   3. Make sure the preset mode is set to "Unsigned" so the browser can upload directly
#      without exposing your Cloudinary API secret.
VITE_UPLOAD_PRESET=your_upload_preset_here
